{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.11",
        "requirements": "fd_agents/requirements.txt"
      }
    },
    {
      "src": "public",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/api(/.*)?$",
      "dest": "api/index.py"
    },
    {
      "src": "^/health(/.*)?$",
      "dest": "api/index.py"
    },
    {
      "src": "^/optimize(/.*)?$",
      "dest": "api/index.py"
    },
    {
      "src": "^/docs(/.*)?$",
      "dest": "api/index.py"
    },
    {
      "src": "^/openapi\\.json.*$",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "public/$1"
    }
  ],
  "env": {
    "PYTHONUNBUFFERED": "1"
  },
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "memory": 1024
    }
  }
}
