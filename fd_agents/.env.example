# FD Portfolio Optimizer - Environment Configuration
# Copy this to .env and update with your actual values

# ─── GROQ API ────────────────────────────────────────────────────────────
# Get API Key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# LLM Configuration
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2000
LLM_TIMEOUT=30

# Rate Limiting (conservative for free tier)
RATE_LIMIT_RPM=300
RATE_LIMIT_TPM=12000

# ─── PSO ALGORITHM ───────────────────────────────────────────────────────
# Particle Swarm Optimization parameters
PSO_NUM_PARTICLES=60
PSO_NUM_ITERATIONS=200
PSO_INERTIA_WEIGHT=0.729
PSO_COGNITION_COEFF=1.494
PSO_SOCIAL_COEFF=1.494

# ─── API SERVER ──────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ─── ENVIRONMENT ──────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=False
LOG_LEVEL=INFO
